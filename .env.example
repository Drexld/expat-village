# Runtime environment
VITE_APP_ENV=development
VITE_APP_REGION=eu-central-1

# Frontend API gateway (Vercel or backend BFF)
VITE_API_BASE_URL=

# Supabase
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# AI providers
VITE_GROQ_API_KEY=

# Observability
VITE_SENTRY_DSN=

# API security (server-side env, do not prefix with VITE in real deployment)
API_CORS_ORIGINS=http://localhost:5173,https://expat-village.vercel.app
API_RATE_LIMIT_READ_MAX=120
API_RATE_LIMIT_WRITE_MAX=40
API_RATE_LIMIT_AI_MAX=20
API_RATE_LIMIT_AUTH_MAX=10
API_RATE_LIMIT_UPLOAD_MAX=15
API_RATE_LIMIT_WINDOW_MS=60000
API_ALLOW_UNVERIFIED_TOKENS=false

# Optional server-side Supabase verification (recommended for protected endpoints)
SUPABASE_URL=
SUPABASE_ANON_KEY=
